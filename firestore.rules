rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      // User can read their own document
      allow read: if request.auth != null && request.auth.uid == uid;

      // Admin can read all user documents
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";

      // User can update ONLY their own lastSession field — not role or other fields
      allow update: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["lastSession"]);

      // Admin can write everything
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";

      // Allow initial creation
      allow create: if request.auth != null;
    }
  }
}
